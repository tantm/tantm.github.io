---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getPublishedPosts } from '../lib/posts';
import { AUTHOR, AUTHOR_TITLE, AVATAR, GITHUB_URL, CATEGORY_META } from '../consts';

const posts = await getPublishedPosts();
const latest = posts.slice(0, 5);
const counts = new Map<string, number>();
for (const p of posts) counts.set(p.data.category, (counts.get(p.data.category) ?? 0) + 1);
---

<BaseLayout wide>
  <section class="hero">
    <img class="hero-avatar" src={AVATAR} alt={AUTHOR} width="120" height="120" />
    <div>
      <h1>Hi, I'm <span class="grad-text">Tân</span> 👋</h1>
      <p class="hero-role">{AUTHOR_TITLE}</p>
      <p class="hero-desc">
        I build data platforms and AI systems for a living, and write down what survives
        contact with production — data engineering, GenAI/agents, architecture and developer
        tooling. Practical notes, always anonymized.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/blog">Read the blog</a>
        <a class="btn btn-outline" href="/profile">About me</a>
        <a class="btn btn-outline" href={GITHUB_URL}>GitHub</a>
      </div>
    </div>
  </section>

  <section>
    <div class="section-head">
      <h2>Topics</h2>
      <a href="/categories">All categories →</a>
    </div>
    <div class="topic-grid">
      {
        CATEGORY_META.map((c) => (
          <a class="topic-card" href={`/categories/${c.slug}`} data-cat={c.slug}>
            <span class="topic-icon">{c.icon}</span>
            <h3>{c.name}</h3>
            <p>{c.description}</p>
            <span class="topic-count">
              {counts.get(c.name) ?? 0} post{(counts.get(c.name) ?? 0) !== 1 ? 's' : ''}
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <section>
    <div class="section-head">
      <h2>Latest posts</h2>
      <a href="/blog">All posts →</a>
    </div>
    <ul class="post-list">
      {latest.map((post) => <PostCard post={post} />)}
    </ul>
  </section>
</BaseLayout>
