---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CategoryBody from '../../../components/pages/CategoryBody.astro';
import { getPublishedPosts, type Post } from '../../../lib/posts';
import { CATEGORY_META } from '../../../consts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const groups = new Map<string, { name: string; posts: Post[] }>();
  for (const post of posts) {
    const key = post.data.category.toLowerCase();
    if (!groups.has(key)) groups.set(key, { name: post.data.category, posts: [] });
    groups.get(key)!.posts.push(post);
  }
  return [...groups.entries()].map(([key, group]) => ({
    params: { category: key },
    props: group,
  }));
}

const { name, posts } = Astro.props;
const slug = name.toLowerCase();
const meta = CATEGORY_META.find((c) => c.slug === slug);
---

<BaseLayout
  title={`Chủ đề: ${name}`}
  description={meta?.description.vi ?? `Bài viết trong chủ đề ${name}.`}
  lang="vi"
  translationUrl={`/categories/${slug}`}
>
  <CategoryBody name={name} posts={posts} lang="vi" />
</BaseLayout>
