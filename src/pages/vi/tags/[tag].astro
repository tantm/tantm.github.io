---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TagBody from '../../../components/pages/TagBody.astro';
import { getPublishedPosts, slugifyTag, type Post } from '../../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const groups = new Map<string, { name: string; posts: Post[] }>();
  for (const post of posts) {
    for (const tag of post.data.tags) {
      const key = slugifyTag(tag);
      if (!groups.has(key)) groups.set(key, { name: tag, posts: [] });
      groups.get(key)!.posts.push(post);
    }
  }
  return [...groups.entries()].map(([key, group]) => ({ params: { tag: key }, props: group }));
}

const { name, posts } = Astro.props;
const { tag } = Astro.params;
---

<BaseLayout
  title={`Thẻ: ${name}`}
  description={`Bài viết gắn thẻ ${name}.`}
  lang="vi"
  translationUrl={`/tags/${tag}`}
>
  <TagBody name={name} posts={posts} lang="vi" />
</BaseLayout>
