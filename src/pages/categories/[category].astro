---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPublishedPosts, type Post } from '../../lib/posts';
import { CATEGORY_META } from '../../consts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const groups = new Map<string, { name: string; posts: Post[] }>();
  for (const post of posts) {
    const key = post.data.category.toLowerCase();
    if (!groups.has(key)) groups.set(key, { name: post.data.category, posts: [] });
    groups.get(key)!.posts.push(post);
  }
  return [...groups.entries()].map(([key, group]) => ({
    params: { category: key },
    props: group,
  }));
}

const { name, posts } = Astro.props;
const slug = name.toLowerCase();
const meta = CATEGORY_META.find((c) => c.slug === slug);
---

<BaseLayout title={`Category: ${name}`} description={meta?.description ?? `Posts in category ${name}.`}>
  <header class="cat-header" data-cat={slug}>
    {meta && <span class="topic-icon">{meta.icon}</span>}
    <div>
      <h1>{name}</h1>
      {meta && <p class="cat-desc">{meta.description}</p>}
    </div>
  </header>
  <p style="color: var(--fg-muted);">
    {posts.length} post{posts.length !== 1 ? 's' : ''} ·
    <a href="/categories">all categories</a>
  </p>
  <ul class="post-list">
    {posts.map((post) => <PostCard post={post} />)}
  </ul>
</BaseLayout>
