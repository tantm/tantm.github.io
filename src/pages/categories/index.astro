---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../../lib/posts';
import { CATEGORY_META } from '../../consts';

const posts = await getPublishedPosts();
const counts = new Map<string, number>();
for (const post of posts) {
  const c = post.data.category;
  counts.set(c, (counts.get(c) ?? 0) + 1);
}
---

<BaseLayout title="Categories" description="Browse posts by topic — Data, AI, Architecture, Developer.">
  <h1>Categories</h1>
  <p style="color: var(--fg-muted); margin-top: 0.25rem;">
    Everything on this site, grouped by topic.
  </p>
  <div class="topic-grid">
    {
      CATEGORY_META.map((c) => (
        <a class="topic-card" href={`/categories/${c.slug}`} data-cat={c.slug}>
          <span class="topic-icon">{c.icon}</span>
          <h3>{c.name}</h3>
          <p>{c.description}</p>
          <span class="topic-count">
            {counts.get(c.name) ?? 0} post{(counts.get(c.name) ?? 0) !== 1 ? 's' : ''}
          </span>
        </a>
      ))
    }
  </div>
</BaseLayout>
