---
import type { Page } from 'astro';
import PostCard from '../PostCard.astro';
import Pagination from '../Pagination.astro';
import { formatDate, readingTime, type Post } from '../../lib/posts';
import { CATEGORY_META } from '../../consts';
import { localePath, useT, type Lang } from '../../i18n';

interface Props {
  page: Page<Post>;
  lang: Lang;
  totalPosts: number;
}

const { page, lang, totalPosts } = Astro.props;
const t = useT(lang);
const isFirst = page.currentPage === 1;
const featured = isFirst ? page.data[0] : null;
const rest = isFirst ? page.data.slice(1) : page.data;
const featIcon = featured && CATEGORY_META.find((c) => c.slug === featured.data.category.toLowerCase())?.icon;
---

<h1>{t('blog.title')}</h1>
<p style="color: var(--fg-muted); margin-top: 0.25rem;">
  {totalPosts} {lang === 'vi' ? '' : `post${totalPosts !== 1 ? 's' : ''} `}{t('blog.counting')}
  <a href={localePath(lang, '/search')}>{t('blog.search')}</a>.
</p>

<div class="filter-bar">
  <a class="chip active" href={localePath(lang, '/blog')}>{t('blog.all')}</a>
  {
    CATEGORY_META.map((c) => (
      <a class="chip" href={localePath(lang, `/categories/${c.slug}`)} data-cat={c.slug}>
        {c.icon} {c.name}
      </a>
    ))
  }
</div>

{
  featured && (
    <a
      class="featured-card"
      href={`/blog/${featured.id}`}
      data-cat={featured.data.category.toLowerCase()}
    >
      <div class="card-cover">
        {featIcon && <span class="cover-icon">{featIcon}</span>}
        <span class="cover-word">{featured.data.category}</span>
      </div>
      <div class="card-body">
        <span class="featured-label">★ {t('blog.featured')}</span>
        <h2>{featured.data.title}</h2>
        {featured.data.description && <p class="desc">{featured.data.description}</p>}
        <div class="post-meta">
          <span class="badge">{featured.data.category}</span>
          {featured.data.lang === 'vi' && <span class="lang-badge">VI</span>}
          <time datetime={featured.data.date.toISOString()}>{formatDate(featured.data.date)}</time>
          <span class="dot" />
          <span>
            {readingTime(featured.body)} {t('post.minRead')}
          </span>
        </div>
      </div>
    </a>
  )
}

<ul class="post-list">
  {rest.map((post) => <PostCard post={post} lang={lang} />)}
</ul>

<Pagination page={page} lang={lang} />
