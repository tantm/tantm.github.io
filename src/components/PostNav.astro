---
import type { Post } from '../lib/posts';
import { useT, type Lang } from '../i18n';

interface Props {
  older: Post | null;
  newer: Post | null;
  lang?: Lang;
}

const { older, newer, lang = 'en' } = Astro.props;
const t = useT(lang);
---

{
  (older || newer) && (
    <nav class="post-nav" aria-label="Post navigation">
      {older ? (
        <a href={`/blog/${older.id}`}>
          <span class="label">{t('post.older')}</span>
          <span class="title">{older.data.title}</span>
        </a>
      ) : (
        <span class="spacer" />
      )}
      {newer ? (
        <a href={`/blog/${newer.id}`} class="next">
          <span class="label">{t('post.newer')}</span>
          <span class="title">{newer.data.title}</span>
        </a>
      ) : (
        <span class="spacer" />
      )}
    </nav>
  )
}
