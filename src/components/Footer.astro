---
import { AUTHOR, SITE_TITLE, SITE_TAGLINE, GITHUB_URL, CATEGORY_META } from '../consts';
import { localePath, useT, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const t = useT(lang);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href={localePath(lang, '/')} class="site-brand">{SITE_TITLE}<span style="color: var(--accent)">.</span></a>
        <p>{SITE_TAGLINE} — {t('footer.tagline')}</p>
      </div>
      <div class="footer-col">
        <h4>{t('footer.topics')}</h4>
        <ul>
          {
            CATEGORY_META.map((c) => (
              <li>
                <a href={localePath(lang, `/categories/${c.slug}`)}>{c.name}</a>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="footer-col">
        <h4>{t('footer.links')}</h4>
        <ul>
          <li><a href={localePath(lang, '/profile')}>{t('footer.about')}</a></li>
          <li><a href={GITHUB_URL}>GitHub</a></li>
          <li><a href={localePath(lang, '/search')}>{t('nav.search')}</a></li>
          <li><a href="/rss.xml">{t('footer.rss')}</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© {year} {AUTHOR}. {t('footer.rights')}</span>
      <span>{t('footer.built')} <a href="https://astro.build">Astro</a> · {t('footer.hosted')}</span>
    </div>
  </div>
</footer>
